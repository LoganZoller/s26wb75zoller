extends layout

block content
  h1= title
  p Logan Zoller Egg Images

  - let image_names = ['cardinal.jpg', 'ostrich.jpg', 'chicken.jpg', 'robin.jpg', 'mockingbird.jpg']
  - for(let i = 0; i < 3; i++)
    - let index = Math.floor(Math.random()*5)
    - let name = image_names[index]
    img(src=`/images/${name}`  alt=name width="300" height="300")

