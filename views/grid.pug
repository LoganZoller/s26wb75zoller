extends layout

block content
  h1= title
  p rows: #{query.rows}
  p cols: #{query.cols}

  - let rows = Number(query.rows)
  - let cols = Number(query.cols)
  if !Number.isInteger(rows) || !Number.isInteger(cols)
    p Error: must be Integers
  else if rows < 2 || rows > 12
    p Error: rows must be between 2 and 12
  else if cols < 2 || cols > 12
    p Error: columns must be between 2 and 12
  else 
    table#outer
        - for(let i = 0; i < 10; i++) {
            tr#middle
                - for(let j = 0, i < 10; i++) {
                    td = (2 * i - j)
                - }
        - }


